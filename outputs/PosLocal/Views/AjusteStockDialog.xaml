<Window x:Class="PosLocal.Views.AjusteStockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Ajuste de Stock"
        Width="460"
        Height="420"
        MinWidth="440"
        MinHeight="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Ajuste de Stock Manual" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding ProductoNombre}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="Stock actual" Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="{Binding StockActual, StringFormat={}{0:0.##}}"
                               DockPanel.Dock="Right"
                               FontSize="20"
                               FontWeight="Bold" />
                </DockPanel>

                <UniformGrid Columns="2" Margin="0,0,0,14">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SumarCommand}" Content="Sumar unidades" Margin="0,0,6,0" />
                    <Button Style="{StaticResource ButtonStyle}" Command="{Binding RestarCommand}" Content="Restar unidades" Margin="6,0,0,0" />
                </UniformGrid>

                <TextBlock Text="Cantidad" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Motivo del ajuste" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,6" />
                <TextBox Style="{StaticResource InputStyle}"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Text="{Binding Motivo, UpdateSourceTrigger=PropertyChanged}" />

                <DockPanel Margin="0,16,0,0">
                    <TextBlock Text="Stock resultante" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding StockResultante, StringFormat={}{0:0.##}}"
                               DockPanel.Dock="Right"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource GreenBrush}" />
                </DockPanel>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Style="{StaticResource ButtonStyle}" Command="{Binding CancelarCommand}" Content="Cancelar" />
                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AplicarCommand}" Content="Aplicar ajuste" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
