<Window x:Class="PosLocal.Views.MontoLibreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Monto"
        Width="390"
        Height="300"
        MinWidth="390"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="50" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Agregar Monto"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Text="Importe manual para la venta actual"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <TextBox Grid.Row="1"
                     Style="{StaticResource InputStyle}"
                     VerticalAlignment="Center"
                     Text="{Binding Monto, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource DialogButtonStyle}"
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar" />
                <Button Style="{StaticResource PrimaryDialogButtonStyle}"
                        Command="{Binding AplicarCommand}"
                        Content="Agregar"
                        Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
