<Window x:Class="PosLocal.Views.ComprasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Compras - Despensa Isabel"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarComprasCommand}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0C10" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111217" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9F7AEA" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FB923C" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,20,0,8" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#20232E" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#252133" />
            <Setter Property="BorderBrush" Value="#3B3158" />
        </Style>

        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center" />
                                <ScrollViewer x:Name="PART_ContentHost" Margin="44,0,12,0" />
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="44,0,12,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataGridDarkStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="66" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="RowBackground" Value="#141721" />
            <Setter Property="AlternatingRowBackground" Value="#171A24" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="StockProgressStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Background" Value="#272B36" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{StaticResource AccentBrush}"
                            DockPanel.Dock="Left">
                        <TextBlock Text="D"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="18" />
                    </Border>

                    <TextBlock Text="&#xE70D;"
                               Style="{StaticResource IconTextStyle}"
                               DockPanel.Dock="Right"
                               Margin="8,0,0,0" />

                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Despensa Isabel"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="#8b74 - Propietario"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACION" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Punto de Venta"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           Style="{StaticResource IconTextStyle}"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonActiveStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE8C7;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Compras"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CATALOGO" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE7B8;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE80A;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>

                        <StackPanel Margin="36,8,0,0">
                            <TextBlock Text="Productos" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="Movimientos" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <TextBlock Text="PERSONAS" Style="{StaticResource SectionCaptionStyle}" />

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Clientes">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Proveedores">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Usuarios">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                        </StackPanel>

                        <TextBlock Text="AN&#xC1;LISIS" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}"
                                Click="AbrirReportes_Click">
                            <DockPanel>
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="#0E1118"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,14,0,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32"
                                    Height="32"
                                    CornerRadius="16"
                                    Background="#12241D"
                                    DockPanel.Dock="Left">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource GreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Background="#302344"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    DockPanel.Dock="Right">
                                <TextBlock Text="Abierta" FontSize="11" Foreground="#D9C7FF" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="$1000.00" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Apertura: 09:00"
                                   Margin="0,12,0,12"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <Button Style="{StaticResource GhostButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Gestionar Caja" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DockPanel Grid.Row="3">
                    <Border Width="38"
                            Height="38"
                            CornerRadius="19"
                            Background="#202331"
                            DockPanel.Dock="Left">
                        <TextBlock Text="A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="&#xE70D;"
                               Style="{StaticResource IconTextStyle}"
                               DockPanel.Dock="Right" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Alejandro" FontWeight="SemiBold" />
                        <TextBlock Text="@alecazon14"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="{StaticResource AppBackgroundBrush}"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,22">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Compras"
                                   FontSize="34"
                                   FontWeight="Bold" />
                        <TextBlock Text="Gestiona el historial de compras y el control de stock asociado"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            DockPanel.Dock="Right"
                            Command="{Binding NuevaCompraCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontWeight="Bold" />
                            <TextBlock Text="Nueva compra" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource WatermarkTextBoxStyle}"
                                 Tag="Buscar por producto, unidad o usuario..."
                                 Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding BuscarComprasCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="12,0,0,0">
                            <Button Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding LimpiarBusquedaCommand}"
                                    Content="Limpiar" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,0,0,0"
                                    Command="{Binding BuscarComprasCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Text="Buscar" Margin="8,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Historial de Compras"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14" />

                        <DataGrid x:Name="ComprasDataGrid"
                                  Grid.Row="1"
                                  Style="{StaticResource DataGridDarkStyle}"
                                  ItemsSource="{Binding Compras}"
                                  SelectedItem="{Binding CompraSeleccionada, Mode=TwoWay}"
                                  behaviors:MouseDoubleClickCommandBehavior.Command="{Binding VerDetalleCommand}"
                                  behaviors:MouseDoubleClickCommandBehavior.CommandParameter="{Binding SelectedItem, ElementName=ComprasDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Producto" Width="2.1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProductoNombre}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding CodigoBarras}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy}}" Width="120" />
                                <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" Width="120" />
                                <DataGridTextColumn Header="Costo unitario" Binding="{Binding CostoUnitario, StringFormat={}{0:C}}" Width="140" />
                                <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadTexto}" Width="110" />
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat={}{0:C}}" Width="130" />
                                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="130" />
                                <DataGridTemplateColumn Header="Acciones" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding DataContext.VerDetalleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Ver detalle">
                                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <DockPanel Grid.Row="2" Margin="0,16,0,0">
                            <TextBlock Text="{Binding MostrandoTexto}"
                                       DockPanel.Dock="Left"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding PaginaAnteriorCommand}"
                                        Content="Atras" />
                                <Border Background="#241F33"
                                        BorderBrush="#3A3152"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16,10"
                                        Margin="8,0">
                                    <TextBlock Text="{Binding PaginaActualTexto}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentHoverBrush}" />
                                </Border>
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding PaginaSiguienteCommand}"
                                        Content="Siguiente" />
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,18,0,0"
                        Visibility="{Binding HayDetalleSeleccionado, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid DataContext="{Binding DetalleSeleccionado}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{Binding ProductoNombre}"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding AuditoriaTexto}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C}}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource GreenBrush}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#10131A"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="ESTADO DEL STOCK"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,14" />

                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding StockResumenTexto}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding StockPorcentaje, StringFormat={}{0:0}%}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource AccentHoverBrush}"
                                                   FontWeight="SemiBold" />
                                    </DockPanel>

                                    <ProgressBar Style="{StaticResource StockProgressStyle}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding StockPorcentaje}" />

                                    <TextBlock Text="{Binding CantidadAlmacenTexto}"
                                               Margin="0,16,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" />

                                    <Border Background="#2B1519"
                                            BorderBrush="#5C252F"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,14,0,0">
                                        <DockPanel>
                                            <Border Width="10"
                                                    Height="10"
                                                    CornerRadius="5"
                                                    Background="{StaticResource DangerBrush}"
                                                    DockPanel.Dock="Left"
                                                    Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding CantidadCriticaTexto}"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       FontWeight="SemiBold" />
                                        </DockPanel>
                                    </Border>

                                    <TextBlock Text="{Binding ProximaEntregaTexto}"
                                               Margin="0,14,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#10131A"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="PROVEEDOR"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,14" />

                                    <TextBlock Text="Nombre" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding ProveedorNombre}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,3,0,14" />

                                    <TextBlock Text="Contacto" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding ProveedorContactoTexto}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,3,0,14"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="Ultimo Pedido" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding UltimoPedidoTexto}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <DockPanel Grid.Row="2" Margin="0,18,0,0">
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    DockPanel.Dock="Left"
                                    Command="{Binding DataContext.VerMovimientosInventarioCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" />
                                    <TextBlock Text="Ver Movimientos de Inventario de este Producto" Margin="8,0,0,0" />
                                </StackPanel>
                            </Button>

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding DataContext.ExportarHistorialCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" />
                                        <TextBlock Text="Exportar historial" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="10,0,0,0"
                                        Command="{Binding DataContext.NuevaCompraCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontWeight="Bold" />
                                        <TextBlock Text="Nueva compra" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Background="#10131A"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,18,0,0">
                    <TextBlock Text="{Binding MensajeEstado}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
