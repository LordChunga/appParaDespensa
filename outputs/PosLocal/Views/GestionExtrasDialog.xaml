<Window x:Class="PosLocal.Views.GestionExtrasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Extras"
        Width="500"
        Height="500"
        MinWidth="500"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />

        <Style x:Key="ToggleOptionStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Gestionar Extras"
                           FontSize="24"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Subtotal, StringFormat=Subtotal actual: {0:C}}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,22,0,0">
                <TextBlock Text="Tipo de ajuste" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                <UniformGrid Columns="2">
                    <RadioButton Style="{StaticResource ToggleOptionStyle}"
                                 GroupName="TipoAjuste"
                                 Content="Descuento"
                                 IsChecked="True"
                                 Command="{Binding SeleccionarDescuentoCommand}"
                                 Margin="0,0,6,0" />
                    <RadioButton Style="{StaticResource ToggleOptionStyle}"
                                 GroupName="TipoAjuste"
                                 Content="Recargo"
                                 Command="{Binding SeleccionarRecargoCommand}"
                                 Margin="6,0,0,0" />
                </UniformGrid>

                <TextBlock Text="Tipo de calculo" Foreground="{StaticResource TextMutedBrush}" Margin="0,18,0,8" />
                <UniformGrid Columns="2">
                    <RadioButton Style="{StaticResource ToggleOptionStyle}"
                                 GroupName="TipoCalculo"
                                 Content="Porcentaje (%)"
                                 IsChecked="True"
                                 Command="{Binding SeleccionarPorcentajeCommand}"
                                 Margin="0,0,6,0" />
                    <RadioButton Style="{StaticResource ToggleOptionStyle}"
                                 GroupName="TipoCalculo"
                                 Content="Monto fijo ($)"
                                 Command="{Binding SeleccionarMontoFijoCommand}"
                                 Margin="6,0,0,0" />
                </UniformGrid>

                <TextBlock Text="Valor del ajuste" Foreground="{StaticResource TextMutedBrush}" Margin="0,18,0,8" />
                <TextBox Style="{StaticResource InputStyle}"
                         Text="{Binding Valor, UpdateSourceTrigger=PropertyChanged}" />

                <Border Background="#10131A"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,22,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Ajuste a aplicar" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding AjusteAplicar, StringFormat={}{0:C}}"
                                       DockPanel.Dock="Right"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DangerBrush}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Nuevo total" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding NuevoTotal, StringFormat={}{0:C}}"
                                       DockPanel.Dock="Right"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource GreenBrush}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Style="{StaticResource DialogButtonStyle}"
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar" />
                <Button Style="{StaticResource PrimaryDialogButtonStyle}"
                        Command="{Binding AplicarCommand}"
                        Content="Aplicar"
                        Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
