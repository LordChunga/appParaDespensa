<Window x:Class="PosLocal.Views.PuntoVentaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        xmlns:vm="clr-namespace:PosLocal.ViewModels"
        Title="Punto de Venta - Despensa Isabel"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        behaviors:KeyboardWedgeBehavior.IsEnabled="True"
        behaviors:KeyboardWedgeBehavior.MinimumLength="4"
        behaviors:KeyboardWedgeBehavior.InterKeyTimeoutMilliseconds="90"
        behaviors:KeyboardWedgeBehavior.ScanCompletedCommand="{Binding ProcesarCodigoBarrasCommand}">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding ProcesarDobleEnterCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0C10" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111217" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9F7AEA" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="BlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#FB923C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,20,0,8" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#20232E" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="QuantityButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#252133" />
            <Setter Property="BorderBrush" Value="#3B3158" />
        </Style>

        <Style x:Key="NavPuntoVentaButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionPuntoVenta}">
                    <Setter Property="Background" Value="#252133" />
                    <Setter Property="BorderBrush" Value="#3B3158" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavTransferenciasButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionTransferencias}">
                    <Setter Property="Background" Value="#252133" />
                    <Setter Property="BorderBrush" Value="#3B3158" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavSistemaButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionSistema}">
                    <Setter Property="Background" Value="#252133" />
                    <Setter Property="BorderBrush" Value="#3B3158" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#303442"
                                    BorderBrush="#444A5C"
                                    BorderThickness="1"
                                    CornerRadius="14" />
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Margin="4,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="#CBD1DF" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#FFFFFF" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center" />
                                <ScrollViewer x:Name="PART_ContentHost" Margin="44,0,12,0" />
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="44,0,12,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CartItemTemplate" DataType="{x:Type vm:CarritoVentaItemViewModel}">
            <Border Background="#141721"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{Binding NombreMostrado}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       DockPanel.Dock="Left" />
                            <Border Background="#203329"
                                    BorderBrush="#315947"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    Margin="12,0,0,0"
                                    DockPanel.Dock="Right">
                                <TextBlock Text="{Binding StockTexto}"
                                           FontSize="11"
                                           Foreground="{StaticResource GreenBrush}" />
                            </Border>
                        </DockPanel>

                        <TextBlock Text="{Binding CodigoMostrado, StringFormat=Codigo: {0}}"
                                   Margin="0,5,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" />

                        <TextBlock Text="{Binding PrecioUnitario, StringFormat=Precio unitario: {0:C}}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0,0,0">
                        <Button Style="{StaticResource QuantityButtonStyle}"
                                Command="{Binding DataContext.DecrementarCantidadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Restar unidad">
                            <TextBlock Text="-" FontSize="18" />
                        </Button>

                        <TextBlock Text="{Binding CantidadTexto}"
                                   MinWidth="70"
                                   Margin="10,0"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontWeight="SemiBold" />

                        <Button Style="{StaticResource QuantityButtonStyle}"
                                Command="{Binding DataContext.IncrementarCantidadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Sumar unidad">
                            <TextBlock Text="+" FontSize="18" />
                        </Button>

                        <Button Style="{StaticResource QuantityButtonStyle}"
                                Margin="12,0,0,0"
                                Command="{Binding DataContext.EliminarItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Eliminar item">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource DangerBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SettingToggleTemplate" DataType="{x:Type vm:SettingToggleItemViewModel}">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42"
                            Height="42"
                            CornerRadius="8"
                            Background="#202331"
                            BorderBrush="#303545"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource AccentHoverBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,18,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,5,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{StaticResource AccentBrush}"
                            DockPanel.Dock="Left">
                        <TextBlock Text="D"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="18" />
                    </Border>

                    <TextBlock Text="&#xE70D;"
                               Style="{StaticResource IconTextStyle}"
                               DockPanel.Dock="Right"
                               Margin="8,0,0,0" />

                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Despensa Isabel"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="#8b74 - Propietario"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACION" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavPuntoVentaButtonStyle}"
                                Command="{Binding MostrarPuntoVentaCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Punto de Venta"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="&#xE70D;"
                                           Style="{StaticResource IconTextStyle}"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE8C7;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Compras" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CATALOGO" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE7B8;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE80A;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>

                        <StackPanel Margin="36,8,0,0">
                            <TextBlock Text="Productos" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="Movimientos" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <TextBlock Text="PERSONAS" Style="{StaticResource SectionCaptionStyle}" />

                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" Background="#241F33" BorderBrush="#3A3152" ToolTip="Clientes">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentHoverBrush}" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Proveedores">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Usuarios">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                        </StackPanel>

                        <TextBlock Text="AN&#xC1;LISIS" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}"
                                Click="AbrirReportes_Click">
                            <DockPanel>
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Reportes"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CAJA Y REPORTES" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavTransferenciasButtonStyle}"
                                Command="{Binding MostrarTransferenciasCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Validar Transferencias"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CONFIGURACI&#xD3;N" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE713;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Configuraci&#xF3;n"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;"
                                           Style="{StaticResource IconTextStyle}"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>

                        <Button Style="{StaticResource NavSistemaButtonStyle}"
                                Margin="36,8,0,0"
                                Command="{Binding MostrarSistemaCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE770;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Sistema"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="#0E1118"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,14,0,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32"
                                    Height="32"
                                    CornerRadius="16"
                                    Background="#12241D"
                                    DockPanel.Dock="Left">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource GreenBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Background="#302344"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    DockPanel.Dock="Right">
                                <TextBlock Text="Abierta"
                                           FontSize="11"
                                           Foreground="#D9C7FF" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CajaEfectivoInicial, StringFormat={}{0:C}}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="{Binding CajaHoraApertura, StringFormat=Apertura: {0:HH:mm}}"
                                   Margin="0,12,0,12"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <Button Style="{StaticResource GhostButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Gestionar Caja" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DockPanel Grid.Row="3">
                    <Border Width="38"
                            Height="38"
                            CornerRadius="19"
                            Background="#202331"
                            DockPanel.Dock="Left">
                        <TextBlock Text="A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="&#xE70D;"
                               Style="{StaticResource IconTextStyle}"
                               DockPanel.Dock="Right" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Alejandro" FontWeight="SemiBold" />
                        <TextBlock Text="@alecazon14"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppBackgroundBrush}">
            <Grid x:Name="SalesContent" Margin="28">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionPuntoVenta}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,22">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Punto de Venta"
                                   FontSize="34"
                                   FontWeight="Bold" />
                        <TextBlock Text="Sistema POS Desktop - Despensa Isabel"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource IconButtonStyle}" ToolTip="Cambiar tema">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Tutorial" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Ayuda F1" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Buscar Producto"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,14" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource WatermarkTextBoxStyle}"
                                             Tag="Buscar producto..."
                                             Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding BuscarProductoCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="12,0,0,0">
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding ConsultarPrecioCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" />
                                                <TextBlock Text="Consultar Precio" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding IngresarPesoCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" />
                                                <TextBlock Text="Ingresar Peso" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding AgregarMontoCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="+" />
                                                <TextBlock Text="Agregar Monto" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding MensajeEstado}"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                    <TextBlock Text="{Binding TotalItemsTexto}"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="Carrito"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="El carrito esta vacio"
                                                   Foreground="{StaticResource TextMutedBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CarritoVacio}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Carrito}"
                                                      ItemTemplate="{StaticResource CartItemTemplate}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CarritoVacio}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                MaxWidth="340">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CarritoVacio}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="&#xE7BF;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="72"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="Carrito vacio"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   Margin="0,18,0,6" />
                                        <TextBlock Text="Busca productos para agregar al carrito"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Cliente"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" />
                                <ComboBox ItemsSource="{Binding Clientes}"
                                          SelectedItem="{Binding ClienteSeleccionado}"
                                          Height="42"
                                          Background="#10131A"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrushSoft}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding TotalItemsTexto}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C}}"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </DockPanel>

                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Descuentos" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding DescuentoTotal, StringFormat=-{0:C}}"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource DangerBrush}" />
                                </DockPanel>

                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Recargos" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding RecargoTotal, StringFormat=+{0:C}}"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource OrangeBrush}" />
                                </DockPanel>

                                <Border Height="1"
                                        Background="{StaticResource BorderBrushSoft}"
                                        Margin="0,8,0,18" />

                                <DockPanel>
                                    <TextBlock Text="Total"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Total, StringFormat={}{0:C}}"
                                               DockPanel.Dock="Right"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource GreenBrush}" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,22,0,0">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Height="54"
                                        Command="{Binding ProcesarVentaCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" />
                                        <TextBlock Text="Procesar Venta (Doble Enter)" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Height="48"
                                        Margin="0,10,0,0"
                                        Command="{Binding GestionarExtrasCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="%" FontWeight="Bold" />
                                        <TextBlock Text="Gestionar Extras" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="#10131A"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,18,0,0">
                    <TextBlock Text="{Binding MensajeEstado}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Border>
            </Grid>

            <Grid x:Name="SystemContent" Margin="28">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionSistema}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,22">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Sistema"
                                   FontSize="34"
                                   FontWeight="Bold" />
                        <TextBlock Text="Activ&#xE1; o desactiv&#xE1; funcionalidades del sistema seg&#xFA;n tus necesidades."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="980"
                                HorizontalAlignment="Left">
                        <TextBlock Text="CONFIGURACIONES GENERALES"
                                   Style="{StaticResource SectionCaptionStyle}"
                                   Margin="4,0,0,10" />

                        <ItemsControl ItemsSource="{Binding GeneralSettings}"
                                      ItemTemplate="{StaticResource SettingToggleTemplate}" />

                        <TextBlock Text="M&#xF3;dulos del plan - Funcionalidades adicionales habilitadas"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,24,0,4" />
                        <TextBlock Text="Los cambios se guardan autom&#xE1;ticamente en el archivo local de configuraci&#xF3;n."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,16" />

                        <TextBlock Text="PLAN PRO"
                                   Style="{StaticResource SectionCaptionStyle}"
                                   Margin="4,0,0,10" />

                        <ItemsControl ItemsSource="{Binding PlanProSettings}"
                                      ItemTemplate="{StaticResource SettingToggleTemplate}" />

                        <TextBlock Text="PLAN IA"
                                   Style="{StaticResource SectionCaptionStyle}"
                                   Margin="4,14,0,10" />

                        <ItemsControl ItemsSource="{Binding PlanIaSettings}"
                                      ItemTemplate="{StaticResource SettingToggleTemplate}" />

                        <Border Background="#10131A"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Margin="0,14,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource BlueBrush}"
                                           FontSize="18"
                                           DockPanel.Dock="Left"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="{Binding SettingsPath, StringFormat=Archivo local: {0}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="TransfersContent" Margin="28">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SeccionActiva}" Value="{x:Static vm:PuntoVentaViewModel.SeccionTransferencias}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,22">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Validar Transferencias"
                                   FontSize="32"
                                   FontWeight="Bold" />
                        <TextBlock Text="Ventas con pago por transferencia pendientes de conciliacion"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Style="{StaticResource GhostButtonStyle}"
                            DockPanel.Dock="Right"
                            Command="{Binding MostrarPuntoVentaCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Text="Volver al POS" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <DataGrid ItemsSource="{Binding TransferenciasPendientes}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowBackground="#141721"
                              AlternatingRowBackground="#171A24"
                              Background="{StaticResource PanelBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="{StaticResource BorderBrushSoft}"
                              GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Venta" Binding="{Binding Numero}" Width="110" />
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="160" />
                            <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:C}}" Width="130" />
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="160" />
                            <DataGridTemplateColumn Header="Accion" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding DataContext.AprobarTransferenciaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" />
                                                <TextBlock Text="Aprobar" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
