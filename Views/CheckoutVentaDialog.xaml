<Window x:Class="PosLocal.Views.CheckoutVentaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Procesar Venta"
        Width="860"
        Height="620"
        MinWidth="820"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="BlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#FB923C" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PaymentButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="92" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Procesar Venta"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,0,0,18" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#10131A"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Resumen de Venta"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Cliente, StringFormat=Cliente: {0}}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" Margin="0,16,0,16">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock Text="{Binding TotalLinea, StringFormat={}{0:C}}"
                                                       DockPanel.Dock="Right"
                                                       FontWeight="SemiBold" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding Nombre}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding CantidadTexto}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C}}" DockPanel.Dock="Right" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Extras" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Recargo, StringFormat=+{0:C}}" DockPanel.Dock="Right" />
                            </DockPanel>
                            <Border Height="1" Background="{StaticResource BorderBrushSoft}" Margin="0,6,0,12" />
                            <DockPanel>
                                <TextBlock Text="Total Final" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Total, StringFormat={}{0:C}}"
                                           DockPanel.Dock="Right"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource GreenBrush}" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1">
                    <CheckBox Content="Varios pagos"
                              IsChecked="{Binding UsaPagosMixtos}"
                              Foreground="#F5F7FB"
                              Margin="0,0,0,16" />

                    <UniformGrid Columns="2" Rows="2">
                        <RadioButton Style="{StaticResource PaymentButtonStyle}"
                                     GroupName="MetodoPago"
                                     IsChecked="True"
                                     Command="{Binding SeleccionarEfectivoCommand}"
                                     Margin="0,0,8,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xEAFD;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource GreenBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Efectivo" Margin="0,8,0,0" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaymentButtonStyle}"
                                     GroupName="MetodoPago"
                                     Command="{Binding SeleccionarTarjetaCommand}"
                                     Margin="8,0,0,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8C7;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource BlueBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Tarjeta" Margin="0,8,0,0" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaymentButtonStyle}"
                                     GroupName="MetodoPago"
                                     Command="{Binding SeleccionarTransferenciaCommand}"
                                     Margin="0,8,8,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8D4;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Transferencia" Margin="0,8,0,0" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaymentButtonStyle}"
                                     GroupName="MetodoPago"
                                     Command="{Binding SeleccionarQrCommand}"
                                     Margin="8,8,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8EF;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource OrangeBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="QR" Margin="0,8,0,0" />
                            </StackPanel>
                        </RadioButton>
                    </UniformGrid>

                    <TextBlock Text="Total a pagar / Minimo"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,22,0,8" />
                    <TextBox Style="{StaticResource InputStyle}"
                             Text="{Binding MontoRecibido, UpdateSourceTrigger=PropertyChanged}" />

                    <DockPanel Margin="0,14,0,0">
                        <TextBlock Text="Vuelto" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Vuelto, StringFormat={}{0:C}}"
                                   DockPanel.Dock="Right"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}" />
                    </DockPanel>

                    <Border Background="#201B2B"
                            BorderBrush="#3B3158"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,18,0,0"
                            Visibility="{Binding EsTransferencia, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="La venta quedara como RequiereValidacion hasta conciliar el pago."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Style="{StaticResource DialogButtonStyle}"
                        Command="{Binding CancelarCommand}"
                        Content="Cancelar" />
                <Button Style="{StaticResource PrimaryDialogButtonStyle}"
                        Command="{Binding ConfirmarCommand}"
                        Content="Confirmar Venta"
                        Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
