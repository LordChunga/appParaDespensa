<Window x:Class="PosLocal.Views.ProductoManualDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Producto"
        Width="720"
        Height="760"
        MinWidth="680"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        behaviors:LoadedCommandBehavior.Command="{Binding InicializarCommand}"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Producto" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Carga o edita un producto del catalogo" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,14">
                        <TextBlock Text="Codigo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,14">
                        <TextBlock Text="Codigo de Barras" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding CodigoBarras, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                        <TextBlock Text="Nombre" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,14">
                        <TextBlock Text="Categoria" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <ComboBox Style="{StaticResource ComboStyle}" ItemsSource="{Binding Categorias}" SelectedItem="{Binding CategoriaSeleccionada}" DisplayMemberPath="Nombre" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,14">
                        <TextBlock Text="Proveedor" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <ComboBox Style="{StaticResource ComboStyle}" ItemsSource="{Binding Proveedores}" SelectedItem="{Binding ProveedorSeleccionado}" DisplayMemberPath="Nombre" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,14">
                        <TextBlock Text="Stock Actual" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding StockActual, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,14">
                        <TextBlock Text="Unidad" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding UnidadMedida, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,14">
                        <TextBlock Text="Stock Minimo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding StockMinimo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,14">
                        <TextBlock Text="Stock Maximo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding StockMaximo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,8,14">
                        <TextBlock Text="Precio Costo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding PrecioCosto, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="8,0,0,14">
                        <TextBlock Text="Precio Venta" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Text="{Binding PrecioVenta, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="2">
                        <TextBlock Text="Descripcion" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <TextBox Style="{StaticResource InputStyle}" Height="72" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <CheckBox Content="Activo" IsChecked="{Binding Activo}" Foreground="#F5F7FB" Margin="0,0,18,0" />
                            <CheckBox Content="Venta por peso" IsChecked="{Binding VentaPorPeso}" Foreground="#F5F7FB" Margin="0,0,18,0" />
                            <TextBlock Text="Peso base" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0" />
                            <TextBox Width="90" Style="{StaticResource InputStyle}" Text="{Binding PesoBaseGramos, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Style="{StaticResource ButtonStyle}" Command="{Binding CancelarCommand}" Content="Cancelar" />
                <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding GuardarCommand}" Content="Guardar" Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
