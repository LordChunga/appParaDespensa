<Window x:Class="PosLocal.Views.GestionProveedoresDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Gestionar Proveedores"
        Width="820"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarCommand}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="22" Margin="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,18">
                <TextBlock Text="Gestionar Proveedores" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Estos proveedores alimentan la carga manual de productos" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Proveedores}" SelectedItem="{Binding ProveedorSeleccionado}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="#10131A" Foreground="#F5F7FB" GridLinesVisibility="None" Margin="0,0,16,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proveedor" Binding="{Binding Nombre}" Width="*" />
                    <DataGridTextColumn Header="Telefono" Binding="{Binding Telefono}" Width="130" />
                    <DataGridTextColumn Header="Productos" Binding="{Binding ProductosAsignados}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBlock Text="Nombre del Proveedor" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Telefono / Contacto" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,6" />
                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Email" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,6" />
                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Notas" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,6" />
                <TextBox Style="{StaticResource InputStyle}" Height="96" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Notas, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Content="Activo" IsChecked="{Binding Activo}" Foreground="#F5F7FB" Margin="0,14,0,0" />
            </StackPanel>

            <DockPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,18,0,0">
                <TextBlock Text="{Binding MensajeEstado}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource ButtonStyle}" Command="{Binding NuevoCommand}" Content="Nuevo" />
                    <Button Style="{StaticResource ButtonStyle}" Command="{Binding EliminarCommand}" Content="Eliminar" Margin="8,0,0,0" />
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding GuardarCommand}" Content="Guardar" Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
