<Window x:Class="PosLocal.Views.InventarioProductosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Inventario - Despensa Isabel"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarCommand}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0C10" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111217" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9F7AEA" />
        <SolidColorBrush x:Key="BlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,20,0,8" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#20232E" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#252133" />
            <Setter Property="BorderBrush" Value="#3B3158" />
        </Style>

        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center" />
                                <ScrollViewer x:Name="PART_ContentHost" Margin="44,0,12,0" />
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="44,0,12,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Width" Value="88" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="DataGridDarkStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="66" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="RowBackground" Value="#141721" />
            <Setter Property="AlternatingRowBackground" Value="#171A24" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#151821" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#151821" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource AccentBrush}" DockPanel.Dock="Left">
                        <TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" />
                    </Border>
                    <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" DockPanel.Dock="Right" Margin="8,0,0,0" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Despensa Isabel" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="#8b74 - Propietario" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACION" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Punto de Venta" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE8C7;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Compras" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CATALOGO" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE7B8;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonActiveStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE80A;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>
                        <StackPanel Margin="36,8,0,0">
                            <Border Background="#241F33" BorderBrush="#3A3152" BorderThickness="1" CornerRadius="8" Padding="10,7" Margin="0,0,0,8">
                                <TextBlock Text="Productos" Foreground="{StaticResource AccentHoverBrush}" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="Movimientos" Foreground="{StaticResource TextMutedBrush}" Margin="10,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="PERSONAS" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE77B;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Clientes" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,6,0,0">
                            <DockPanel>
                                <TextBlock Text="&#xE716;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Usuarios" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="AN&#xC1;LISIS" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}"
                                Click="AbrirReportes_Click">
                            <DockPanel>
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#0E1118" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="16" Background="#12241D" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Background="#302344" CornerRadius="10" Padding="8,3" DockPanel.Dock="Right">
                                <TextBlock Text="Abierta" FontSize="11" Foreground="#D9C7FF" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="$1000.00" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="Apertura: 09:00" Margin="0,12,0,12" Foreground="{StaticResource TextMutedBrush}" />
                        <Button Style="{StaticResource GhostButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Gestionar Caja" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DockPanel Grid.Row="3">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#202331" DockPanel.Dock="Left">
                        <TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" DockPanel.Dock="Right" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Alejandro" FontWeight="SemiBold" />
                        <TextBlock Text="@alecazon14" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppBackgroundBrush}" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Inventario" FontSize="34" FontWeight="Bold" />
                <TextBlock Text="Control y seguimiento de stock de productos de Despensa Isabel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource WatermarkTextBoxStyle}" Tag="Buscar por nombre o codigo..." Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding BuscarCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Margin="12,0,0,0" Command="{Binding AplicarFiltrosCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock Text="Filtros" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                <DataGrid x:Name="InventarioDataGrid"
                          Style="{StaticResource DataGridDarkStyle}"
                          ItemsSource="{Binding Productos}"
                          SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Producto" SortMemberPath="Nombre" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CodigoBarras}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Categoria" SortMemberPath="CategoriaNombre" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#172A3A" BorderBrush="#26547A" BorderThickness="1" CornerRadius="10" Padding="8,3">
                                        <TextBlock Text="{Binding CategoriaNombre}" Foreground="{StaticResource BlueBrush}" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Estado" SortMemberPath="Activo" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton IsChecked="{Binding Activo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Command="{Binding DataContext.CambiarDisponibilidadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"
                                                  Width="62"
                                                  Height="30"
                                                  Background="#27303A"
                                                  Foreground="{StaticResource GreenBrush}"
                                                  Content="POS" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Stock" SortMemberPath="StockActual" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StockTexto}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StockCritico}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Proveedor" Binding="{Binding ProveedorNombre}" SortMemberPath="ProveedorNombre" Width="*" />

                        <DataGridTemplateColumn Header="Acciones" Width="104" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Acciones rapidas">
                                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" />
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                <MenuItem Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding DataContext.AjustarStockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                                            <TextBlock Text="Ajuste de Stock Manual" />
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <MenuItem Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding DataContext.VerMovimientosCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                                            <TextBlock Text="Ver Historial de Movimientos" />
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{Binding MostrandoTexto}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <ComboBox Style="{StaticResource DarkComboBoxStyle}" ItemsSource="{Binding TamañosPagina}" SelectedItem="{Binding TamanoPagina}" Margin="14,0,0,0" />
                </StackPanel>

                <TextBlock Text="{Binding MensajeEstado}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PaginaAnteriorCommand}" Content="Atras" />
                    <Border Background="#241F33" BorderBrush="#3A3152" BorderThickness="1" CornerRadius="8" Padding="16,10" Margin="8,0">
                        <TextBlock Text="{Binding PaginaActualTexto}" FontWeight="SemiBold" Foreground="{StaticResource AccentHoverBrush}" />
                    </Border>
                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PaginaSiguienteCommand}" Content="Siguiente" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
