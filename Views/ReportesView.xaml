<Window x:Class="PosLocal.Views.ReportesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Reportes - Despensa Isabel"
        Width="1400"
        Height="900"
        MinWidth="1220"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        Language="es-AR"
        TextOptions.TextFormattingMode="Display"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarReportesCommand}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0C10" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111217" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="PanelDeepBrush" Color="#10131A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <LinearGradientBrush x:Key="KpiCardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#202333" Offset="0" />
            <GradientStop Color="#151822" Offset="0.62" />
            <GradientStop Color="#10131A" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="BlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,20,0,8" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#20232E" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#252133" />
            <Setter Property="BorderBrush" Value="#3B3158" />
        </Style>

        <Style x:Key="DatePickerDarkStyle" TargetType="DatePicker">
            <Setter Property="Width" Value="138" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelDeepBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PanelSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#151821" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#252133" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#3B3158" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource AccentBrush}" DockPanel.Dock="Left">
                        <TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Despensa Isabel" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="#8b74 - Propietario" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACION" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarPuntoVentaCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Punto de Venta" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarComprasCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE8CB;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Compras" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CATALOGO" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarProductosCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7BF;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarInventarioCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7C3;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="PERSONAS" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE716;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Clientes" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}">
                            <DockPanel>
                                <TextBlock Text="&#xE77B;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Usuarios" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="AN&#xC1;LISIS" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonActiveStyle}"
                                Command="{Binding MostrarReportesCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="2"
                           Text="{Binding MensajeEstado}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="4,16,4,0" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" Background="{StaticResource AppBackgroundBrush}" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="34,30,34,34">
                <DockPanel LastChildFill="True" Margin="0,0,0,24">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding AplicarFiltrosCommand}"
                                Height="40"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="Filtros" />
                            </StackPanel>
                        </Button>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Fecha desde" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,4" />
                            <DatePicker Style="{StaticResource DatePickerDarkStyle}"
                                        SelectedDate="{Binding FechaDesde, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Fecha hasta" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,4" />
                            <DatePicker Style="{StaticResource DatePickerDarkStyle}"
                                        SelectedDate="{Binding FechaHasta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Menu Width="46" Height="40" VerticalAlignment="Bottom">
                            <MenuItem Header="..." Width="46" Height="40">
                                <MenuItem Command="{Binding ExportarReporteCommand}">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                            <TextBlock Text="Exportar CSV" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Reportes" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Analiza el rendimiento de Despensa Isabel"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Kpis}" Margin="-8,0,-8,16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource KpiCardBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="18"
                                    Margin="8"
                                    MinHeight="118">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#242235" DockPanel.Dock="Left">
                                            <TextBlock Text="{Binding Icono}"
                                                       FontFamily="{Binding IconFontFamily}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding Ayuda}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Right"
                                                   DockPanel.Dock="Right"
                                                   FontWeight="Bold" />
                                    </DockPanel>
                                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding Titulo}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Text="{Binding Valor}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8"
                        Margin="0,0,0,16">
                    <TabControl SelectedIndex="0" Height="54">
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                                    <TextBlock Text="Resumen" />
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                                    <TextBlock Text="Ventas" />
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                                    <TextBlock Text="Productos" />
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                                    <TextBlock Text="M&#xE9;todos de pago" />
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
                                    <TextBlock Text="Historial de Caja" />
                                </StackPanel>
                            </TabItem.Header>
                        </TabItem>
                    </TabControl>
                </Border>

                <ItemsControl ItemsSource="{Binding ResumenSecundario}" Margin="-8,0,-8,18">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16"
                                    Margin="8"
                                    MinHeight="100">
                                <DockPanel>
                                    <Border Width="42" Height="42" CornerRadius="21" Background="{Binding ColorClave}" DockPanel.Dock="Left" Margin="0,0,14,0">
                                        <TextBlock Text="{Binding Icono}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Titulo}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                        <TextBlock Text="{Binding Valor}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="17" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding Subtitulo}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.45*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            MinHeight="330"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Ingresos y ganancia por d&#xED;a" Style="{StaticResource PanelTitleStyle}" />
                                <TextBlock Text="Cu&#xE1;nto entr&#xF3; y cu&#xE1;nto qued&#xF3; estimado dentro del per&#xED;odo seleccionado."
                                           Style="{StaticResource PanelSubtitleStyle}" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <lvc:CartesianChart Series="{Binding IngresosGananciaSeries}"
                                                    XAxes="{Binding IngresosGananciaXAxes}"
                                                    YAxes="{Binding MoneyYAxes}"
                                                    LegendPosition="Bottom"
                                                    Background="Transparent" />
                                <TextBlock Text="Sin datos en el per&#xED;odo">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TieneDatosIngresos}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            MinHeight="330"
                            Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="&#xBF;C&#xF3;mo te pagan?" Style="{StaticResource PanelTitleStyle}" />
                                <TextBlock Text="Reparto de las ventas seg&#xFA;n el medio de pago utilizado."
                                           Style="{StaticResource PanelSubtitleStyle}" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <lvc:PieChart Series="{Binding MetodosPagoSeries}"
                                              LegendPosition="Bottom"
                                              Background="Transparent" />
                                <TextBlock Text="Sin operaciones">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TieneMetodosPago}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            MinHeight="220"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Height="36" Padding="12,6">
                                    <TextBlock Text="Ver m&#xE1;s" />
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="Productos que m&#xE1;s ganancia dejan" Style="{StaticResource PanelTitleStyle}" />
                                    <TextBlock Text="Ranking estimado por margen dentro del per&#xED;odo."
                                               Style="{StaticResource PanelSubtitleStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ItemsControl ItemsSource="{Binding ProductosMasGanancia}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,10">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Ganancia, StringFormat=C}" Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding CantidadTexto}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Producto}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Sin datos de ganancia...">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TieneRankingGanancia}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20"
                            MinHeight="220"
                            Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" Height="36" Padding="12,6">
                                    <TextBlock Text="Ver m&#xE1;s" />
                                </Button>
                                <StackPanel>
                                    <TextBlock Text="Productos m&#xE1;s vendidos" Style="{StaticResource PanelTitleStyle}" />
                                    <TextBlock Text="Unidades vendidas por producto en el per&#xED;odo seleccionado."
                                               Style="{StaticResource PanelSubtitleStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,18,0,0">
                                <ItemsControl ItemsSource="{Binding ProductosMasVendidos}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,10">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding CantidadTexto}" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding Total, StringFormat=C}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Producto}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Sin ventas registradas...">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TieneRankingVentas}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
