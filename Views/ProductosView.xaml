<Window x:Class="PosLocal.Views.ProductosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Productos - Despensa Isabel"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarProductosCommand}">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0C10" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#111217" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9F7AEA" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <SolidColorBrush x:Key="BlueBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />

        <Style x:Key="IconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="4,20,0,8" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#20232E" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#252133" />
            <Setter Property="BorderBrush" Value="#3B3158" />
        </Style>

        <Style x:Key="WatermarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="&#xE721;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center" />
                                <ScrollViewer x:Name="PART_ContentHost" Margin="44,0,12,0" />
                                <TextBlock x:Name="Watermark"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="44,0,12,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="DataGridDarkStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="66" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="RowBackground" Value="#141721" />
            <Setter Property="AlternatingRowBackground" Value="#171A24" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DarkMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#151821" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="286" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource AccentBrush}" DockPanel.Dock="Left">
                        <TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="18" />
                    </Border>
                    <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" DockPanel.Dock="Right" Margin="8,0,0,0" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Despensa Isabel" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="#8b74 - Propietario" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="OPERACION" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarPuntoVentaCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Punto de Venta" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Command="{Binding MostrarComprasCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE8C7;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Compras" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>

                        <TextBlock Text="CATALOGO" Style="{StaticResource SectionCaptionStyle}" />
                        <Button Style="{StaticResource NavButtonActiveStyle}"
                                Command="{Binding MostrarProductosCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE7B8;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                            </DockPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Margin="0,6,0,0"
                                Command="{Binding MostrarInventarioCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE80A;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Button>
                        <StackPanel Margin="36,8,0,0">
                            <TextBlock Text="Productos" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="Movimientos" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <TextBlock Text="PERSONAS" Style="{StaticResource SectionCaptionStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Clientes">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Proveedores">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="Usuarios">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                        </StackPanel>

                        <TextBlock Text="AN&#xC1;LISIS" Style="{StaticResource SectionCaptionStyle}" />

                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding MostrarReportesCommand}">
                            <DockPanel>
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#0E1118" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,14">
                    <StackPanel>
                        <DockPanel>
                            <Border Width="32" Height="32" CornerRadius="16" Background="#12241D" DockPanel.Dock="Left">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource GreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Background="#302344" CornerRadius="10" Padding="8,3" DockPanel.Dock="Right">
                                <TextBlock Text="Abierta" FontSize="11" Foreground="#D9C7FF" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Mi Caja" FontWeight="SemiBold" />
                                <TextBlock Text="$1000.00" Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="Apertura: 09:00" Margin="0,12,0,12" Foreground="{StaticResource TextMutedBrush}" />
                        <Button Style="{StaticResource GhostButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Gestionar Caja" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <DockPanel Grid.Row="3">
                    <Border Width="38" Height="38" CornerRadius="19" Background="#202331" DockPanel.Dock="Left">
                        <TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="&#xE70D;" Style="{StaticResource IconTextStyle}" DockPanel.Dock="Right" />
                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="Alejandro" FontWeight="SemiBold" />
                        <TextBlock Text="@alecazon14" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppBackgroundBrush}" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,22">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Productos" FontSize="34" FontWeight="Bold" />
                    <TextBlock Text="Gestiona el inventario de Despensa Isabel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AbrirNuevoProductoCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontWeight="Bold" />
                            <TextBlock Text="Nuevo Producto" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>

                    <Menu Style="{StaticResource DarkMenuStyle}" Margin="10,0,0,0">
                        <MenuItem Style="{StaticResource DarkMenuItemStyle}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Mas opciones" />
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Margin="8,1,0,0" />
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Style="{StaticResource DarkMenuItemStyle}" Command="{Binding ExportarCsvCommand}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                        <TextBlock Text="Exportar CSV" />
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource DarkMenuItemStyle}" Command="{Binding ImportarCsvCommand}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                        <TextBlock Text="Importar CSV" />
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <MenuItem Style="{StaticResource DarkMenuItemStyle}" Command="{Binding GestionarCategoriasCommand}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                        <TextBlock Text="Gestionar Categorias" />
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource DarkMenuItemStyle}" Command="{Binding GestionarProveedoresCommand}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                        <TextBlock Text="Gestionar Proveedores" />
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Style="{StaticResource DarkMenuItemStyle}" Command="{Binding NuevoComboCommand}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" />
                                        <TextBlock Text="Nuevo Combo" />
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Style="{StaticResource WatermarkTextBoxStyle}" Tag="Buscar por nombre o codigo..." Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding BuscarProductosCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                        <ComboBox Style="{StaticResource DarkComboBoxStyle}" ItemsSource="{Binding Categorias}" SelectedItem="{Binding CategoriaSeleccionada}" DisplayMemberPath="Nombre" />
                        <ComboBox Style="{StaticResource DarkComboBoxStyle}" Margin="8,0,0,0" ItemsSource="{Binding Proveedores}" SelectedItem="{Binding ProveedorSeleccionado}" DisplayMemberPath="Nombre" />
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Command="{Binding LimpiarFiltrosCommand}" Content="Limpiar" />
                        <Button Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" Command="{Binding AplicarFiltrosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" />
                                <TextBlock Text="Filtros" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16">
                <DataGrid x:Name="ProductosDataGrid"
                          Style="{StaticResource DataGridDarkStyle}"
                          ItemsSource="{Binding Productos}"
                          SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="" Binding="{Binding Seleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52" CanUserSort="False" />
                        <DataGridTemplateColumn Header="Producto" SortMemberPath="Nombre" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CodigoBarras}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Categoria" SortMemberPath="CategoriaNombre" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#172A3A" BorderBrush="#26547A" BorderThickness="1" CornerRadius="10" Padding="8,3">
                                        <TextBlock Text="{Binding CategoriaNombre}" Foreground="{StaticResource BlueBrush}" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Estado" SortMemberPath="Activo" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton IsChecked="{Binding Activo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Command="{Binding DataContext.CambiarEstadoProductoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"
                                                  Width="62"
                                                  Height="30"
                                                  Background="#27303A"
                                                  Foreground="{StaticResource GreenBrush}"
                                                  Content="ON" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Stock" Binding="{Binding StockTexto}" SortMemberPath="StockActual" Width="100" />
                        <DataGridTextColumn Header="Venta" Binding="{Binding PrecioVentaTexto}" SortMemberPath="PrecioVenta" Width="120" />
                        <DataGridTextColumn Header="Neto" Binding="{Binding PrecioNetoTexto}" SortMemberPath="PrecioCosto" Width="120" />
                        <DataGridTextColumn Header="Proveedor" Binding="{Binding ProveedorNombre}" SortMemberPath="ProveedorNombre" Width="170" />
                        <DataGridTemplateColumn Header="Acciones" Width="96" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding DataContext.EditarProductoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Editar producto">
                                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Background="#10131A" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,18,0,0">
                <TextBlock Text="{Binding MensajeEstado}" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>
    </Grid>
</Window>
