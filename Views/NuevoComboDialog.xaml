<Window x:Class="PosLocal.Views.NuevoComboDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:PosLocal.Behaviors"
        Title="Nuevo Combo"
        Width="980"
        Height="720"
        MinWidth="900"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#0B0C10"
        Foreground="#F5F7FB"
        FontFamily="Segoe UI"
        behaviors:LoadedCommandBehavior.Command="{Binding CargarCommand}"
        behaviors:CloseWindowOnTrueBehavior.CloseWhenTrue="{Binding DebeCerrar}">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171923" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1D202B" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B2F3B" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A9B0C2" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6F7789" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#34D399" />
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#10131A" />
            <Setter Property="Foreground" Value="#F5F7FB" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="22" Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Nuevo Combo" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Crea packs o promociones que descuentan stock de sus productos internos" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Codigo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding Codigo, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                    <TextBlock Text="Codigo de Barras" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding CodigoBarras, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="8,0,8,0">
                    <TextBlock Text="Nombre" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="8,0,8,0">
                    <TextBlock Text="Sugerido" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding PrecioSugerido, StringFormat={}{0:C}}" Height="42" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="{StaticResource GreenBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="8,0,0,0">
                    <TextBlock Text="Precio Combo" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource InputStyle}" Text="{Binding PrecioCombo, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#10131A" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBox Style="{StaticResource InputStyle}" Text="{Binding TextoBusquedaProducto, UpdateSourceTrigger=PropertyChanged}" Width="300" />
                            <Button Style="{StaticResource ButtonStyle}" Command="{Binding BuscarProductosCommand}" Content="Buscar" DockPanel.Dock="Right" Margin="10,0,0,0" />
                        </DockPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ProductosDisponibles}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="#10131A" Foreground="#F5F7FB" GridLinesVisibility="None">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" Width="*" />
                                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioVenta, StringFormat={}{0:C}}" Width="100" />
                                <DataGridTemplateColumn Header="" Width="72">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ButtonStyle}" Command="{Binding DataContext.AgregarProductoCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="+" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#10131A" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8,0,0,0">
                    <DataGrid ItemsSource="{Binding Detalles}" AutoGenerateColumns="False" CanUserAddRows="False" Background="#10131A" Foreground="#F5F7FB" GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding Nombre}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" Width="78" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalLinea, StringFormat={}{0:C}}" IsReadOnly="True" Width="110" />
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ButtonStyle}" Command="{Binding DataContext.QuitarProductoCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Quitar" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <DockPanel Grid.Row="3" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding AhorroTexto}" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding MensajeEstado}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource ButtonStyle}" Command="{Binding CancelarCommand}" Content="Cancelar" />
                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding GuardarCommand}" Content="Guardar Combo" Margin="10,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
